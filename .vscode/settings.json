{
  "liveServer.settings.ignoreFiles": [
    "**/.vscode/**",
    "**/.git/**",
    "**/.svn/**",
    "**/.hg/**",
    "**/CVS/**",
    "**/.DS_Store/**",
    "**/node_modules/**",
    "**/backend/dev.db",
    "**/backend/dev.db-journal",
    "**/backend/uploads/**"
  ],
  "files.watcherExclude": {
    "**/backend/dev.db": true,
    "**/backend/dev.db-journal": true,
    "**/backend/uploads/**": true
  }
}
